# ============================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env — ele contém senhas e API keys
# ============================================================

# === OpenAI ===
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...sua-chave-aqui...

# === Keycloak OAuth (validação e obtenção de tokens) ===
KEYCLOAK_URL=http://localhost:8080
REALM=sereduc-mcps
CLIENT_ID=ser-mcp-client
# Secret do cliente no Keycloak (Clients > ser-mcp-client > Credentials)
CLIENT_SECRET=seu-client-secret-aqui

# === MCP Server ===
MCP_URL=http://localhost:8081/mcp

# === FastAPI Server ===
HOST=0.0.0.0
PORT=8081

# === Banco de Dados Local (mock) ===
DATABASE_FILE=database.json